# .env.example — MiaotongDoc 环境变量模板

# ===== 数据库 =====
POSTGRES_DB=miaotongdocdb
POSTGRES_USER=miaotong
DB_PASSWORD=your_db_password_here

# ===== Redis =====
REDIS_PASSWORD=your_redis_password_here

# ===== 应用 JWT =====
APP_JWT_SECRET=your_app_jwt_secret_min_32_chars_here
APP_JWT_EXPIRATION=7200000

# ===== 文档编辑器 =====
EDITOR_JWT_SECRET=your_editor_jwt_secret_here

# ===== SSO 单点登录 =====
SSO_ENABLED=false
SSO_PROVIDER_NAME=银行统一认证
SSO_ISSUER_URI=https://sso.bank.com/realms/miaotong
SSO_CLIENT_ID=miaotongdoc
SSO_CLIENT_SECRET=your_sso_client_secret_here
SSO_AUTO_PROVISION=true
SSO_SUCCESS_REDIRECT=/home.html
SSO_FAILURE_REDIRECT=/login.html?error=sso_failed

# ===== CORS =====
CORS_ORIGINS=https://doc.bank.com
