# ================================================================
# MiaotongDoc 环境变量配置
# ================================================================
# 使用说明：
#   1. 复制此文件：cp .env.example .env
#   2. 修改 .env 中的密码和密钥（不要使用默认值）
#   3. 启动服务：./deploy.sh start
#
# 安全提示：
#   - 所有密码和密钥必须在生产环境中修改
#   - .env 文件包含敏感信息，不要提交到 Git
#   - 建议密码长度 >= 16 位，包含大小写字母、数字和特殊字符
# ================================================================


# ===== 数据库配置 =====
# PostgreSQL 数据库名称（自动创建，无需修改）
POSTGRES_DB=miaotongdocdb

# PostgreSQL 数据库用户（自动创建，无需修改）
POSTGRES_USER=miaotong

# PostgreSQL 数据库密码
# 用于：postgres 容器、web-server 连接数据库、editor 连接数据库
# 要求：长度 >= 8 位，生产环境建议 16 位以上
DB_PASSWORD=miaotong2024

# ===== Redis 配置 =====
# Redis 缓存密码
# 用于：redis 容器、web-server 连接 Redis、editor 连接 Redis
# 要求：长度 >= 8 位
REDIS_PASSWORD=miaotong2024

# ===== RabbitMQ 配置 =====
# RabbitMQ 消息队列密码
# 用于：rabbitmq 容器、editor 连接 RabbitMQ（协同编辑消息传递）
# 要求：长度 >= 8 位
RABBITMQ_PASSWORD=miaotong2024

# ===== OnlyOffice 安全链接密钥 =====
# OnlyOffice 文档服务器的安全链接密钥
# 用于：editor 容器内部文件访问签名
# 要求：长度 >= 16 位，生产环境建议修改
SECURE_LINK_SECRET=miaotongdoc2024securelink

# ===== 应用 JWT 配置 =====
# 后端应用的 JWT 签名密钥
# 用于：用户登录 Token 签发和验证
# 要求：长度 >= 32 位，生产环境必须修改
APP_JWT_SECRET=miaotongdoc-jwt-secret-key-2024-very-long-string

# JWT Token 过期时间（毫秒）
# 默认：7200000ms = 2 小时
# 可选值：3600000（1小时）、7200000（2小时）、86400000（24小时）
APP_JWT_EXPIRATION=7200000

# ===== 编辑器 JWT 配置 =====
# OnlyOffice 编辑器的 JWT 签名密钥
# 用于：后端与 OnlyOffice 编辑器之间的 Token 验证
# 要求：长度 >= 32 位，生产环境必须修改
# 注意：此密钥必须与 OnlyOffice 编辑器配置一致
EDITOR_JWT_SECRET=miaotongdoc-editor-jwt-secret-2024-32bytes!

# ===== 跨域配置 =====
# 允许的前端访问来源（CORS）
# 用于：浏览器跨域请求验证
# 格式：多个域名用逗号分隔，不要有空格
# 示例：https://doc.bank.com,https://admin.bank.com
# 开发环境：http://localhost
# 生产环境：https://你的域名
CORS_ORIGINS=http://localhost

# ===== SSO 单点登录配置（可选）=====
# 是否启用 SSO 单点登录
# 可选值：true（启用）、false（禁用）
SSO_ENABLED=false

# SSO 服务器地址（SSO 启用时必填）
# 示例：https://sso.bank.com/realms/miaotong
SSO_ISSUER_URI=

# SSO 客户端 ID（SSO 启用时必填）
# 示例：miaotongdoc
SSO_CLIENT_ID=

# SSO 客户端密钥（SSO 启用时必填）
SSO_CLIENT_SECRET=

# SSO 提供商显示名称
# 用于：登录页面显示的 SSO 按钮文字
SSO_PROVIDER_NAME=统一认证

# SSO 自动创建用户（SSO 启用时可选）
# 可选值：true（自动创建）、false（不自动创建）
# 当 SSO 用户首次登录时，自动在系统中创建对应用户
SSO_AUTO_PROVISION=true

# SSO 登录成功后跳转地址
SSO_SUCCESS_REDIRECT=/home.html

# SSO 登录失败后跳转地址
SSO_FAILURE_REDIRECT=/login.html?error=sso_failed

# ===== 存储配置 =====
# 文档存储类型
# 可选值：
#   local - 本地文件系统（开发环境、单机部署）
#   minio - MinIO 对象存储（生产环境、多机部署）
#
# local 模式：文件存储在 data/documents/ 目录
# minio 模式：文件存储在 MinIO 服务中
STORAGE_TYPE=minio

# MinIO 访问密钥（storage.type=minio 时必填）
# 用于：MinIO 控制台登录、API 访问认证
# 要求：长度 >= 8 位
MINIO_ACCESS_KEY=miaotong

# MinIO 秘密密钥（storage.type=minio 时必填）
# 用于：MinIO API 访问认证
# 要求：长度 >= 8 位，生产环境必须修改
MINIO_SECRET_KEY=miaotong2024minio

# MinIO 存储桶名称（storage.type=minio 时必填）
# 用于：存储文档文件的 MinIO 桶
# 命名规则：小写字母、数字、连字符，长度 3-63 位
MINIO_BUCKET=miaotongdoc

# ===== 缓存清理配置 =====
# OnlyOffice 编辑器缓存最大保留时间（小时）
# 用于：cache-cleaner 容器自动清理过期缓存
# 默认：24 小时
# 缓存目录：data/editor-cache/（临时编辑文件、已关闭文档残留文件）
CACHE_MAX_AGE_HOURS=24

# ===== AI 大模型配置（可选）=====
# 内网大模型 API 地址（OpenAI 兼容格式，带 /v1）
# 示例：http://192.168.1.100:8080/v1
LLM_API_URL=http://192.24.129.1:31000/v1

# 大模型 API 密钥（如无需密钥可留空）
LLM_API_KEY=sk-dd9cd5a11645e76830645d390cdf0ab2

# 大模型 API 超时时间（秒）
LLM_TIMEOUT=300
